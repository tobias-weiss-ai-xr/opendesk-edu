---
commonAnnotations: {}

bigbluebutton:
  image: "ghcr.io/<your-org>/greenlight-saml"
  tag: "v1.3.0"
  replicaCount: 2

  # Greenlight SAML configuration for Sharad
  greenlight:
    default_registration: "saml"
    saml:
      idp_entityId: "https://id.opendesk.example.com/realms/opendesk"
      idp_sso_target_url: "https://id.opendesk.example.com/realms/opendesk/protocol/saml"
      sp_entityId: "https://bbb.opendesk.example.com/shibboleth"

# Ingress configuration
ingress:
  enabled: true
  className: "haproxy"
  annotations:
    haproxy-ingress.github.io/ssl-redirect: "true"
    haproxy-ingress.github.io/timeout-server: "120000ms"
    haproxy-ingress.github.io/timeout-client: "120000ms"
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
  hosts:
    host: "bbb.opendesk.example.com"
    paths:
      path: /
      pathType: "ImplementationSpecific"
  tls:
    secretName: "opendesk-certificates-tls"
    hosts:
      - "bbb.opendesk.example.com"

# Shibboleth configuration
shibboleth:
  enabled: true
  sp:
    host: "bbb.opendesk.example.com"
    entityID: "https://bbb.opendesk.example.com/shibboleth"

# BoldChat SAML configuration
boldchat:
  enabled: true
  label: "OpenDesk Login"
  icon: //img.icons8.com/color/96/lock.png
  provider: :saml
  params:
    assertion_consumer_service_url: "https://bbb.opendesk.example.com/auth/saml2/callback"
    sp_entity_id: "https://bbb.opendesk.example.com/shibboleth"
    idp_entity_id: "https://id.opendesk.example.com/realms/opendesk"
    idp_sso_target_url: "https://id.opendesk.example.com/realms/opendesk/protocol/saml"
    idp_slo_target_url: "https://id.opendesk.example.com/realms/opendesk/protocol/saml"
    idp_metadata_url: "https://id.opendesk.example.com/realms/opendesk/protocol/saml/descriptor"
    allowed_clock_drift: 120
  secrets:
    certificate: /etc/shibboleth/shib-cert.pem
    private_key: /etc/shibboleth/shib-key.pem
  recordings:
    require_login: false
    allow_guests: false

# Service configuration
service:
  annotations: {}
  externalPort: 80
  enabled: true
