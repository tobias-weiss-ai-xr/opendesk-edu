---
## Backchannel Logout Configuration
##
## This file configures SAML backchannel logout for educational services.
## Backchannel logout enables centralized logout from the portal to propagate
## to all services including Moodle, BigBlueButton, OpenCloud, and Nextcloud.
##
## Overview:
## Users can logout from the portal and have their sessions terminated across
## all services via SAML backchannel logout or OIDC backchannel logout.
## This is critical for security (prevents orphaned sessions) and compliance
## (GDPR Right to be Forgotten, logout on request).
##
## Prerequisites:
## - Keycloak SSO configured as central authentication provider
## - SAML/OIDC identity provider enabled for each service
## - Services deployed and accessible
##
## Enable backchannel logout: Set `.Values.backchannelLogout.enabled: true`
##

backchannelLogout:

  ## Enable backchannel logout for educational services
  ##
  enabled: {{ env "BACKCHANNEL_LOGOUT_ENABLED" | default "true" | quote }}

  # NOTE: Defaults for backchannel logout can be overridden via environment variables
  # e.g. BACKCHANNEL_LOGOUT_ENABLED, BACKCHANNEL_LOGOUT_MOODLE_ENABLED, etc.

  ## SAML Backchannel Logout Configuration
  ##
  ## Backchannel logout for SAML-based services (Moodle, BigBlueButton)
  ## Uses SAML 2.0 SLO (Single Logout) with backchannel binding
  ##
  saml:

    ## Backchannel logout for Moodle
    ##
    ## Moodle uses Apache Shibboleth (mod_shib) for SAML authentication.
    ## Backchannel logout terminates Moodle sessions when Keycloak logout is triggered.
    ##
    moodle:
      ## Enable SAML backchannel logout for Moodle
      ##
      enabled: {{ env "BACKCHANNEL_LOGOUT_MOODLE_ENABLED" | default "true" | quote }}

      ## Backchannel logout listener endpoint
      ## Keycloak sends logout requests to this endpoint
      ##
      backchannelLogoutUrl: {{ env "BACKCHANNEL_LOGOUT_MOODLE_URL" | default (printf "https://moodle.%s/Shibboleth.sso/Logout" .Values.global.domain) | quote }}

      ## Frontchannel logout endpoint (fallback, user-visible redirect)
      ## Used when backchannel is unavailable or as secondary method
      ##
      frontchannelLogoutUrl: {{ env "BACKCHANNEL_LOGOUT_MOODLE_FRONTCHANNEL_URL" | default (printf "https://moodle.%s/auth/shibboleth/logout.php" .Values.global.domain) | quote }}

      ## SAML logout bindings supported
      ## Moodle Apache Shibboleth supports multiple logout bindings.
      ##
      bindings:
        ## HTTP-Redirect binding: URL parameter-based logout request
        ## Fast but visible in browser address bar
        ##
        httpRedirect: {{ env "BACKCHANNEL_LOGOUT_MOODLE_REDIRECT_BINDING" | default "true" | quote }}

        ## HTTP-POST binding: Form POST-based logout request
        ## More secure, not visible in address bar
        ##
        httpPost: {{ env "BACKCHANNEL_LOGOUT_MOODLE_POST_BINDING" | default "true" | quote }}

        ## SOAP binding: XML-based logout request
        ## Used for backchannel logout (server-to-server)
        ##
        soap: {{ env "BACKCHANNEL_LOGOUT_MOODLE_SOAP_BINDING" | default "true" | quote }}

      ## Logout request signature requirements
      ##
      signature:
        ## Verify signature on logout requests from Keycloak
        ##
        requireSignedRequests: {{ env "BACKCHANNEL_LOGOUT_MOODLE_REQUIRE_SIGNED_REQUESTS" | default "true" | quote }}

        ## Sign logout responses sent to Keycloak
        ##
        signResponses: {{ env "BACKCHANNEL_LOGOUT_MOODLE_SIGN_RESPONSES" | default "true" | quote }}

      ## Session termination timeout
      ## Time to wait for Moodle session cleanup before considering logout failed
      ## (in seconds)
      ##
      sessionTerminationTimeout: {{ env "BACKCHANNEL_LOGOUT_MOODLE_TIMEOUT" | default "30" | quote }}

      ## Enable verbose logging for debug
      ## Useful for troubleshooting backchannel logout issues
      ##
      verbose: {{ env "BACKCHANNEL_LOGOUT_MOODLE_VERBOSE" | default "false" | quote }}

    ## Backchannel logout for BigBlueButton
    ##
    ## BigBlueButton uses SAML for authentication integration.
    ## Backchannel logout terminates BBB sessions when Keycloak logout is triggered.
    ##
    bigbluebutton:
      ## Enable SAML backchannel logout for BBB
      ##
      enabled: {{ env "BACKCHANNEL_LOGOUT_BBB_ENABLED" | default "true" | quote }}

      ## Backchannel logout listener endpoint
      ##
      backchannelLogoutUrl: {{ env "BACKCHANNEL_LOGOUT_BBB_URL" | default (printf "https://bbb.%s/saml/logout" .Values.global.domain) | quote }}

      ## Frontchannel logout endpoint
      ##
      frontchannelLogoutUrl: {{ env "BACKCHANNEL_LOGOUT_BBB_FRONTCHANNEL_URL" | default (printf "https://bbb.%s/logout" .Values.global.domain) | quote }}

      ## SAML logout bindings supported
      ##
      bindings:
        httpRedirect: {{ env "BACKCHANNEL_LOGOUT_BBB_REDIRECT_BINDING" | default "true" | quote }}
        httpPost: {{ env "BACKCHANNEL_LOGOUT_BBB_POST_BINDING" | default "true" | quote }}
        soap: {{ env "BACKCHANNEL_LOGOUT_BBB_SOAP_BINDING" | default "true" | quote }}

      ## Logout request signature requirements
      ##
      signature:
        requireSignedRequests: {{ env "BACKCHANNEL_LOGOUT_BBB_REQUIRE_SIGNED_REQUESTS" | default "true" | quote }}
        signResponses: {{ env "BACKCHANNEL_LOGOUT_BBB_SIGN_RESPONSES" | default "true" | quote }}

      ## Session termination timeout
      ##
      sessionTerminationTimeout: {{ env "BACKCHANNEL_LOGOUT_BBB_TIMEOUT" | default "30" | quote }}

      ## Verbose logging
      ##
      verbose: {{ env "BACKCHANNEL_LOGOUT_BBB_VERBOSE" | default "false" | quote }}

  ## OIDC Backchannel Logout Configuration
  ##
  ## Backchannel logout for OIDC-based services (OpenCloud, Nextcloud)
  ## Uses OpenID Connect Back-Channel Logout specification
  ##
  oidc:

    ## Backchannel logout for OpenCloud
    ##
    ## OpenCloud uses OIDC for authentication.
    ## Implements OpenID Connect Back-Channel Logout spec (draft-06)
    ##
    opencloud:
      ## Enable OIDC backchannel logout for OpenCloud
      ##
      enabled: {{ env "BACKCHANNEL_LOGOUT_OPENCLOUD_ENABLED" | default "true" | quote }}

      ## Backchannel logout listener endpoint
      ## OpenCloud receives logout POST requests from Keycloak
      ##
      backchannelLogoutUrl: {{ env "BACKCHANNEL_LOGOUT_OPENCLOUD_URL" | default (printf "https://files.%s/backchannel_logout" .Values.global.domain) | quote }}

      ## Logout token verification secret
      ## Shared secret with Keycloak for verifying logout tokens
      ##
      # logoutTokenSecret: {{ .Values.secrets.opencloud.backchannelLogoutSecret | quote }}

      ## Require PKCE (Proof Key for Code Exchange) during logout
      ## Provides additional security for logout tokens
      ##
      requirePkce: {{ env "BACKCHANNEL_LOGOUT_OPENCLOUD_REQUIRE_PKCE" | default "true" | quote }}

      ## Maximum logout token age (in seconds)
      ## Prevents replay attacks with old tokens
      ##
      maxTokenAge: {{ env "BACKCHANNEL_LOGOUT_OPENCLOUD_MAX_TOKEN_AGE" | default "300" | quote }}

      ## Verbose logging
      ##
      verbose: {{ env "BACKCHANNEL_LOGOUT_OPENCLOUD_VERBOSE" | default "false" | quote }}

    ## Backchannel logout for Nextcloud
    ##
    ## Nextcloud uses OIDC via user_oidc plugin.
    ## Implements OpenID Connect Back-Channel Logout spec (draft-06)
    ##
    nextcloud:
      ## Enable OIDC backchannel logout for Nextcloud
      ##
      enabled: {{ env "BACKCHANNEL_LOGOUT_NEXTCLOUD_ENABLED" | default "true" | quote }}

      ## Backchannel logout listener endpoint
      ##
      backchannelLogoutUrl: {{ env "BACKCHANNEL_LOGOUT_NEXTCLOUD_URL" | default (printf "https://nc.%s/apps/user_oidc/backchannel_logout" .Values.global.domain) | quote }}

      ## Logout token verification secret
      ##
      # logoutTokenSecret: {{ .Values.secrets.nextcloud.backchannelLogoutSecret | quote }}

      ## Require PKCE during logout
      ##
      requirePkce: {{ env "BACKCHANNEL_LOGOUT_NEXTCLOUD_REQUIRE_PKCE" | default "true" | quote }}

      ## Maximum logout token age
      ##
      maxTokenAge: {{ env "BACKCHANNEL_LOGOUT_NEXTCLOUD_MAX_TOKEN_AGE" | default "300" | quote }}

      ## Verbose logging
      ##
      verbose: {{ env "BACKCHANNEL_LOGOUT_NEXTCLOUD_VERBOSE" | default "false" | quote }}

  ## Global backchannel logout settings
  ##
  global:

    ## Central logout trigger URL
    ## Users initiate logout from this portal endpoint
    ##
    centralLogoutUrl: {{ env "BACKCHANNEL_LOGOUT_CENTRAL_URL" | default (printf "https://portal.%s/logout" .Values.global.domain) | quote }}

    ## Logout propagation timeout
    ## Overall time limit for completing logout across all services (in seconds)
    ##
    propagationTimeout: {{ env "BACKCHANNEL_LOGOUT_PROPAGATION_TIMEOUT" | default "60" | quote }}

    ## Retry failed backchannel logout attempts
    ##
    retry:
      ## Enable retry for failed backchannel logout
      ##
      enabled: {{ env "BACKCHANNEL_LOGOUT_RETRY_ENABLED" | default "true" | quote }}

      ## Maximum retry attempts per service
      ##
      maxAttempts: {{ env "BACKCHANNEL_LOGOUT_RETRY_MAX_ATTEMPTS" | default "3" | quote }}

      ## Delay between retries (in seconds)
      ##
      delay: {{ env "BACKCHANNEL_LOGOUT_RETRY_DELAY" | default "5" | quote }}

    ## Logging and monitoring
    ##
    logging:
      ## Enable structured logging for backchannel logout events
      ##
      enabled: {{ env "BACKCHANNEL_LOGOUT_LOGGING_ENABLED" | default "true" | quote }}

      ## Log level for backchannel logout
      ## Valid values: debug, info, warn, error
      ##
      level: {{ env "BACKCHANNEL_LOGOUT_LOGGING_LEVEL" | default "info" | quote }}

      ## Log format (for centralized logging)
      ## Valid values: json, text
      ##
      format: {{ env "BACKCHANNEL_LOGOUT_LOGGING_FORMAT" | default "json" | quote }}
