{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "limesurvey": {
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "port": { "type": "integer" },
        "db": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer" },
            "user": { "type": "string" },
            "password": { "type": "string" },
            "name": { "type": "string" },
            "tablePrefix": { "type": "string" }
          }
        },
        "siteName": { "type": "string" },
        "adminName": { "type": "string" },
        "adminEmail": { "type": "string" },
        "timezone": { "type": "string" },
        "volumes": {
          "type": "object",
          "properties": {
            "upload": {
              "type": "object",
              "properties": {
                "size": { "type": "string" },
                "accessMode": { "type": "string" }
              }
            }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["string", "number"] },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["string", "number"] },
                "memory": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretName": { "type": "string" },
              "hosts": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "mariadb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "rootPassword": { "type": "string" },
            "database": { "type": "string" }
          }
        },
        "primary": {
          "type": "object",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
