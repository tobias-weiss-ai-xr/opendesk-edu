{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "selfServicePassword": {
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "port": { "type": "integer" },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["string", "number"] },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["string", "number"] },
                "memory": { "type": "string" }
              }
            }
          }
        },
        "ldap": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "string" },
            "baseDn": { "type": "string" },
            "bindDn": { "type": "string" },
            "startTls": { "type": "string" },
            "networkTimeout": { "type": "string" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    }
  }
}
